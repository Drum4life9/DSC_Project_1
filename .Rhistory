# Cross Minority * Sex
analysis_table_crossed <- data %>%
group_by(minority, sex) %>%
summarise(
N_Obs = n(),
mean = mean(mathgain, na.rm = TRUE),
std_dev = sd(mathgain, na.rm = TRUE),
